INTERPRET_PROVIDER=codex
# INTERPRET_PROVIDER=claude
# INTERPRET_PROVIDER=deepseek

CODEX_MODEL=gpt-5.5
# Options for gpt-5.5: none, low, medium, high, xhigh
CODEX_REASONING_EFFORT=high

CLAUDE_MODEL=claude-sonnet-4-6
# Options: empty string to disable, think hard, ultrathink
CLAUDE_REASONING_EFFORT=ultrathink

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Options: deepseek-v4-flash, deepseek-v4-pro
DEEPSEEK_MODEL=deepseek-v4-pro
# Thinking options: enabled, disabled
DEEPSEEK_THINKING=enabled
# Reasoning options: high, max. Compatibility: low/medium map to high, xhigh maps to max.
DEEPSEEK_REASONING_EFFORT=high
